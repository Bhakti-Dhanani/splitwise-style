# Database
DATABASE_URL=postgresql://user:password@localhost:5432/fairpath

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Vercel URLs (optional - auto-detected in production)
VERCEL_URL=localhost:3000
VERCEL_PROJECT_PRODUCTION_URL=fairpath.vercel.app
V0_RUNTIME_URL=http://localhost:3000

# Node environment
NODE_ENV=development

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

